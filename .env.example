# Server
SHARE_ROOT=/data/netstashd-vault
ADMIN_SECRET=change-me-to-something-random
SESSION_SECRET=change-me-session-secret

# Limits (admin) - accepts human-readable sizes: "10GB", "500MB", etc.
GLOBAL_MAX_BYTES=10GB
RESERVE_BYTES=500MB
MAX_STASH_SIZE_BYTES=5GB
MAX_TTL_DAYS=30

# Limits (guest) - non-admin users creating stashes
GUEST_MAX_STASH_SIZE_BYTES=100MB
GUEST_MAX_TTL_DAYS=7
GUEST_REQUIRE_TTL=true

# Server bind
HOST=0.0.0.0
PORT=8000

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Session persistence (days)
SESSION_MAX_AGE_DAYS=365

# Cleanup settings
EXPIRED_GRACE_DAYS=7         # Days to keep files after stash expires
CLEANUP_ON_STARTUP=true      # Run cleanup when server starts
CLEANUP_INTERVAL_HOURS=6     # Background cleanup interval (0 = disabled)

# Access codes
CODE_TTL_SECONDS=120         # How long temporary access codes are valid

# CLI (for netstashd command)
NETSTASHD_SERVER=http://localhost:8000
NETSTASHD_API_KEY=change-me-to-something-random
